{
    "rewrites": [
        {
            "source": "/sitemap.xml",
            "destination": "https://h4zg81qif5p3tupc8yw676ia.187.127.133.164.sslip.io/sitemap.xml"
        },
        {
            "source": "/blog-sitemap.xml",
            "destination": "https://h4zg81qif5p3tupc8yw676ia.187.127.133.164.sslip.io/blog-sitemap.xml"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/index.html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*).html",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        }
    ]
}